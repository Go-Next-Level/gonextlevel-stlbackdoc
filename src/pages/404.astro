---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found | Back to Wellness Chiropractic">
  <Header />
  <main id="main-content" style="min-height: 70vh; display: flex; align-items: center; justify-content: center; background: var(--color-navy); padding: 120px 0 60px;">
    <div style="text-align: center; padding: 0 1.5rem;">
      <h1 style="font-family: var(--font-display); font-size: clamp(3rem, 8vw, 5rem); font-weight: 700; color: var(--color-teal-light); line-height: 1; margin-bottom: 1rem;">404</h1>
      <p style="font-size: 1.25rem; color: rgba(255,255,255,0.8); margin-bottom: 2rem;">This page took a wrong turn. Let's get you back to wellness.</p>
      <a href="/" class="btn-primary">
        Back to Home
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </main>
  <Footer />
</Layout>