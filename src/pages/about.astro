---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About | Back to Wellness Chiropractic — Kirkwood, MO">
  <Header />
  <main id="main-content">
    <section class="page-banner">
      <div class="container-wide">
        <h1>About Back to Wellness Chiropractic</h1>
        <p>Over 24 years of clinical experience, personalized care, and advanced drug-free therapies in Kirkwood, MO.</p>
      </div>
    </section>

    <!-- Our Story -->
    <section class="section section-light">
      <div class="container-wide">
        <div class="twocol">
          <div data-reveal="left">
            <span class="section-eyebrow">Our Story</span>
            <h2 class="section-title">Committed to Your Healing Journey</h2>
            <p style="font-size: 1rem; color: var(--color-text-light); line-height: 1.8; margin-bottom: 1.25rem;">
              At Back to Wellness Chiropractic, we help people across Kirkwood and the greater St. Louis area find relief from back pain, neck tension, headaches, sciatica, and more — with chiropractic care tailored to your body and lifestyle.
            </p>
            <p style="font-size: 1rem; color: var(--color-text-light); line-height: 1.8; margin-bottom: 1.25rem;">
              Our experienced team focuses on gentle, non-invasive treatment that supports real, lasting results. To support deeper recovery, we offer SoftWave and Red Light Therapy — two drug-free options known for reducing inflammation, improving circulation, and accelerating the body's natural healing process.
            </p>
            <p style="font-size: 1rem; color: var(--color-text-light); line-height: 1.8;">
              Established in 2014 and built on over 24 years of clinical experience, our practice is designed to be warm, welcoming, and fully equipped for comprehensive chiropractic care. From your first consultation to your latest adjustment, we're here to help you feel at ease from day one.
            </p>
          </div>
          <div data-reveal="right" class="twocol-image">
            <img src="/images/chiropractic-care.jpg" alt="Chiropractic care treatment at Back to Wellness Chiropractic" width="700" height="600" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- Core Values -->
    <section class="section section-cream">
      <div class="container-wide">
        <div data-reveal="up" style="margin-bottom: 3rem; text-align: center;">
          <span class="section-eyebrow">What Drives Us</span>
          <h2 class="section-title">Our Core Values</h2>
        </div>
        <div class="grid-3">
          <div data-reveal="up"><div class="card" style="height: 100%; display: flex; flex-direction: column;">
            <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
            <h3 class="card-title">Personalized Care</h3>
            <p class="card-text" style="flex: 1;">We consider the whole person — your symptoms, lifestyle, and goals — to craft a tailored wellness plan that addresses your unique needs, not a one-size-fits-all approach.</p>
          </div></div>
          <div data-reveal="up"><div class="card" style="height: 100%; display: flex; flex-direction: column;">
            <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg></div>
            <h3 class="card-title">Non-Invasive Treatment</h3>
            <p class="card-text" style="flex: 1;">Drug-free, surgery-free therapies that support your body's natural healing process. From adjustments to SoftWave and Red Light, every treatment is gentle and evidence-based.</p>
          </div></div>
          <div data-reveal="up"><div class="card" style="height: 100%; display: flex; flex-direction: column;">
            <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg></div>
            <h3 class="card-title">Accessible & Responsive</h3>
            <p class="card-text" style="flex: 1;">Same-day appointments, affordable $49 initial treatments, and a welcoming office in Kirkwood. We make it easy to start your journey to better health without financial stress.</p>
          </div></div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="section section-navy">
      <div class="container-wide">
        <div class="stats-bar">
          <div class="stat-item" data-reveal="up"><div class="stat-number">24+</div><div class="stat-label">Years of Experience</div></div>
          <div class="stat-item" data-reveal="up"><div class="stat-number">2014</div><div class="stat-label">Established in Kirkwood</div></div>
          <div class="stat-item" data-reveal="up"><div class="stat-number">$49</div><div class="stat-label">Initial Treatments</div></div>
          <div class="stat-item" data-reveal="up"><div class="stat-number">Same-Day</div><div class="stat-label">Appointments Available</div></div>
        </div>
      </div>
    </section>

    <!-- Location -->
    <section class="section section-light" id="location">
      <div class="container-wide">
        <div data-reveal="up" style="text-align: center; margin-bottom: 3rem;">
          <span class="section-eyebrow">Visit Us</span>
          <h2 class="section-title">Our Kirkwood Office</h2>
          <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">Located across the street from our former office, our new space is designed to be warm, welcoming, and fully equipped for your care.</p>
        </div>
        <div data-reveal="up" style="max-width: 800px; margin: 0 auto; border-radius: 14px; overflow: hidden; box-shadow: var(--shadow-lg);">
          <img src="/images/hero-mountain.jpg" alt="Mountain hiking path — representing the wellness journey at Back to Wellness Chiropractic" width="800" height="400" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
        <div style="max-width: 600px; margin: 2rem auto 0; text-align: center;">
          <p style="font-size: 1rem; color: var(--color-text); font-weight: 600; margin-bottom: 0.5rem;">11229 Manchester Road</p>
          <p style="font-size: 1rem; color: var(--color-text-light); margin-bottom: 0.5rem;">Kirkwood, MO 63122</p>
          <p style="font-size: 0.9rem; color: var(--color-text-light);">Lower Level Behind Revel Kitchen</p>
          <a href="/contact" class="btn-primary" style="margin-top: 1.5rem;">Request an Appointment</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-band">
      <div class="container-wide">
        <div data-reveal="up">
          <h2>Ready to Get Back to Wellness?</h2>
          <p>Book your first visit today. Personalized, non-invasive care that meets you where you are.</p>
          <a href="/contact" class="btn-primary">Request an Appointment</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>