---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | Back to Wellness Chiropractic — Kirkwood, MO">
  <Header />
  <main id="main-content">
    <section class="page-banner">
      <div class="container-wide">
        <h1>Let's Get You Back to Wellness</h1>
        <p>We're here to help! Whether you're looking to book an appointment, have a question about our services, or need to know our hours and location, you'll find all the information you need right here.</p>
      </div>
    </section>

    <section class="section section-light">
      <div class="container-wide">
        <div class="contact-grid">
          <!-- Contact Info -->
          <div data-reveal="left">
            <div class="contact-info">
              <h3>Request an Appointment</h3>
              <p style="margin-bottom: 1.5rem;">Call us or fill out the form and we'll get back to you to schedule your visit.</p>

              <div style="margin-bottom: 1.5rem;">
                <p style="font-size: 0.8rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Phone</p>
                <a href="tel:+13143942093" style="font-size: 1.25rem; font-weight: 600; color: var(--color-teal);">(314) 394-2093</a>
              </div>

              <div style="margin-bottom: 1.5rem;">
                <p style="font-size: 0.8rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Address</p>
                <p style="font-size: 1rem; color: var(--color-text);">11229 Manchester Road</p>
                <p style="font-size: 1rem; color: var(--color-text);">Kirkwood, MO 63122</p>
                <p style="font-size: 0.9rem; color: var(--color-text-light); margin-top: 0.25rem;">Lower Level Behind Revel Kitchen</p>
              </div>

              <div style="margin-bottom: 1.5rem;">
                <p style="font-size: 0.8rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Hours</p>
                <div style="font-size: 0.95rem; color: var(--color-text); line-height: 1.8;">
                  <div style="display: flex; justify-content: space-between; max-width: 320px;"><span>Mon, Wed, Thu</span><span>9am-12pm, 2pm-6pm</span></div>
                  <div style="display: flex; justify-content: space-between; max-width: 320px;"><span>Tuesday</span><span>2pm-6pm</span></div>
                  <div style="display: flex; justify-content: space-between; max-width: 320px;"><span>Friday</span><span>9am-12pm</span></div>
                  <div style="display: flex; justify-content: space-between; max-width: 320px;"><span>Sat-Sun</span><span>Closed</span></div>
                </div>
              </div>

              <div style="background: var(--color-teal-soft); border-radius: 12px; padding: 1.25rem 1.5rem;">
                <p style="font-size: 0.9rem; color: var(--color-teal-dark); font-weight: 500; margin-bottom: 0.25rem;">💡 New Patient Specials</p>
                <p style="font-size: 0.85rem; color: var(--color-teal-dark);">$49 SoftWave or Red Light initial consultation and treatment.</p>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div data-reveal="right">
            <div class="card" style="padding: 2.5rem;">
              <h3 style="font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; color: var(--color-navy); margin-bottom: 0.5rem;">Send Us a Message</h3>
              <p style="font-size: 0.9rem; color: var(--color-text-light); margin-bottom: 2rem;">Fill out the form below and we'll reach out to schedule your appointment.</p>

              <form id="contact-form" onsubmit="handleFormSubmit(event)">
                <div class="form-field">
                  <label class="form-label" for="name">Full Name *</label>
                  <input class="form-input" type="text" id="name" name="name" required placeholder="Jane Doe" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="phone">Phone Number *</label>
                  <input class="form-input" type="tel" id="phone" name="phone" required placeholder="(314) 555-0000" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="email">Email Address</label>
                  <input class="form-input" type="email" id="email" name="email" placeholder="jane@example.com" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="service">Service of Interest</label>
                  <select class="form-input" id="service" name="service">
                    <option value="">Select a service...</option>
                    <option value="chiropractic">Chiropractic Care</option>
                    <option value="softwave">SoftWave Therapy ($49 special)</option>
                    <option value="red-light">Red Light Therapy ($49 special)</option>
                    <option value="self-pay">Self-Pay 1st Visit ($150)</option>
                    <option value="general">General Inquiry</option>
                  </select>
                </div>
                <div class="form-field">
                  <label class="form-label" for="message">Message</label>
                  <textarea class="form-input form-textarea" id="message" name="message" placeholder="Tell us about your symptoms or any questions you have..."></textarea>
                </div>
                <button type="submit" class="form-submit">Send Message</button>
                <div class="form-success" id="form-success">
                  ✓ Thank you! We'll reach out to you shortly to schedule your appointment.
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map/Location visual -->
    <section class="section section-cream" style="padding-top: 0;">
      <div class="container-wide">
        <div data-reveal="up" style="border-radius: 14px; overflow: hidden; box-shadow: var(--shadow-lg); max-width: 100%;">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3116.5!2d-90.4!3d38.58!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDM0JzQ4LjAiTiA5MMKwMjQnMDAuMCJX!5e0!3m2!1sen!2sus!4v1000000000000"
            width="100%"
            height="400"
            style="border: 0; display: block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Back to Wellness Chiropractic location map"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-band">
      <div class="container-wide">
        <div data-reveal="up">
          <h2>Prefer to Call?</h2>
          <p>Same-day appointments often available. We're here to help you feel better.</p>
          <a href="tel:+13143942093" class="btn-primary">Call (314) 394-2093</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline>
  function handleFormSubmit(event) {
    event.preventDefault();
    var form = event.target;
    var success = document.getElementById('form-success');
    // Simulated submission — in production, connect to Web3Forms or backend
    form.querySelectorAll('input, select, textarea, button').forEach(function(el) {
      el.disabled = true;
    });
    success.classList.add('show');
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>